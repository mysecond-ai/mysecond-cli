{
  "name": "@mysecond/cli",
  "version": "1.1.0-rc.0",
  "description": "mySecond PM Operating System — CLI installer and sync agent",
  "type": "module",
  "bin": {
    "mysecond": "bin/mysecond.cjs"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
