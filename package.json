    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/tar": "^6.1.13",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mysecond-ai/mysecond-cli.git"
  },
  "homepage": "https://mysecond.ai",
  "license": "UNLICENSED",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2",
    "tar": "^7.5.13"
  }
}
